# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./flowcore.db
DEVELOPMENT_WORKSPACE_MODE=true


# FastAPI Configuration
PORT=8000
HOST=0.0.0.0
DEBUG=true

# ─── Meta WhatsApp Cloud API ────────────────────────────────────────────────
# Your WhatsApp Business number: +919652778472
# Fill these in from your Meta App Dashboard → WhatsApp → API Setup

# The Phone Number ID (not the phone number itself, the META-assigned numeric ID)
META_PHONE_NUMBER_ID=1142214872306990

# WhatsApp Business Account ID (WABA ID)
META_WABA_ID=REPLACE_WITH_YOUR_WABA_ID

# Permanent System User Access Token (from Meta Business Settings → System Users)
META_ACCESS_TOKEN=EAAecwqLXXngBRUeTXnxIx3xWhOsGMQ2oUeODqUSCtVINidNNobltzrod6XqTlk7TJINlINYIu3ReAvqsGU8UT0FmDL1gYGUMxpCIh3VSB315uVwyNK0IFyquQbZC8kIqlIr9MZCNW5ZByUsblP4icrg4keBqPXqWx8wZBZBx1rQr4fwGKSu2MfoBQjwlrzdspmAZDZD

# Webhook Verify Token — you choose this, must match what you set in Meta App Dashboard → Webhooks
META_WEBHOOK_VERIFY_TOKEN=flowcore_webhook_verify_2026

# FlowCore Business ID for this WhatsApp number (Demo Restaurant)
FLOWCORE_BUSINESS_ID=e216b183-8c91-4a56-b819-50ebfb3f8a45

# ─── n8n Orchestration Layer ─────────────────────────────────────────────────
# n8n runs on port 5678 by default (Docker or local)
